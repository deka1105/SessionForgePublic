{
  "name": "sessionforge-browser",
  "productName": "SessionForge",
  "version": "0.1.0",
  "description": "A custom browser where every tab can be its own login session — log in to the same site as multiple users simultaneously.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "dist": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "browser",
    "electron",
    "multi-session",
    "multi-account"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.sessionforge.browser",
    "productName": "SessionForge",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
