{
  "name": "sessionforge-browser",
  "productName": "SessionForge",
  "version": "5.0.0-beta.2",
  "description": "A custom browser where every tab can be its own login session — log in to the same site as multiple users simultaneously.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev":   "electron . --enable-logging",
    "dist":  "electron-builder",
    "pack":  "electron-builder --dir"
  },
  "keywords": ["browser", "electron", "multi-session", "multi-account"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.sessionforge.browser",
    "productName": "SessionForge",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.png",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "win": {
      "icon": "assets/icon.png",
      "target": ["nsis"]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": ["AppImage"]
    }
  }
}
